#!/usr/bin/env bash

set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
PROFILES_DIR="${CLAUDE_DIR}/profiles"
BACKUPS_DIR="${CLAUDE_DIR}/backups"
SETTINGS_FILE="${CLAUDE_DIR}/settings.json"
BACKUP_KEEP_COUNT="${BACKUP_KEEP_COUNT:-50}"

timestamp() {
  date +"%Y%m%d-%H%M%S"
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

ensure_dirs() {
  mkdir -p "$PROFILES_DIR" "$BACKUPS_DIR"
}

validate_profile_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid profile name: $name"
}

profile_path() {
  local name="${1:-}"
  printf '%s/%s.json' "$PROFILES_DIR" "$name"
}

backup_path() {
  local name="${1:-}"
  [[ "$name" != */* ]] || die "Backup name must not contain '/': $name"
  printf '%s/%s' "$BACKUPS_DIR" "$name"
}

json_validator() {
  if has_command jq; then
    printf 'jq'
    return
  fi

  if has_command python3; then
    printf 'python3'
    return
  fi

  die "jq or python3 is required to validate JSON."
}

validate_json() {
  local file="$1"
  local validator
  local err=""
  validator="$(json_validator)"

  if [[ ! -f "$file" ]]; then
    die "JSON file not found: $file"
  fi

  if [[ "$validator" == "jq" ]]; then
    if ! err="$(jq empty "$file" 2>&1 >/dev/null)"; then
      die "Invalid JSON: $file"$'\n'"$err"
    fi
    return
  fi

  if ! err="$(python3 -m json.tool "$file" 2>&1 >/dev/null)"; then
    die "Invalid JSON: $file"$'\n'"$err"
  fi
}

normalize_json() {
  local file="$1"
  local validator
  validator="$(json_validator)"

  if [[ "$validator" == "jq" ]]; then
    jq -S -c . "$file" 2>/dev/null
    return
  fi

  python3 - "$file" 2>/dev/null <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    data = json.load(fh)

print(json.dumps(data, sort_keys=True, separators=(",", ":")))
PY
}

cleanup_old_backups() {
  local -a backups=()
  local remove_count=0
  local i=0

  shopt -s nullglob
  backups=("$BACKUPS_DIR"/settings-*.json)
  shopt -u nullglob

  if (( ${#backups[@]} <= BACKUP_KEEP_COUNT )); then
    return
  fi

  IFS=$'\n' backups=($(printf '%s\n' "${backups[@]}" | sort))
  unset IFS
  remove_count=$((${#backups[@]} - BACKUP_KEEP_COUNT))

  for ((i = 0; i < remove_count; i += 1)); do
    rm -f -- "${backups[$i]}"
  done
}

backup_current() {
  ensure_dirs
  local base_timestamp=""
  local backup_file=""
  local suffix=1

  if [[ ! -f "$SETTINGS_FILE" ]]; then
    printf 'No current settings to back up.\n'
    return 0
  fi

  validate_json "$SETTINGS_FILE"
  base_timestamp="$(timestamp)"
  backup_file="${BACKUPS_DIR}/settings-${base_timestamp}.json"
  while [[ -e "$backup_file" ]]; do
    backup_file="${BACKUPS_DIR}/settings-${base_timestamp}-${suffix}.json"
    suffix=$((suffix + 1))
  done
  cp "$SETTINGS_FILE" "$backup_file"
  cleanup_old_backups
  printf 'Backed up current settings to: %s\n' "$backup_file"
}

list_profiles() {
  ensure_dirs

  local -a files=()
  local file

  shopt -s nullglob
  files=("$PROFILES_DIR"/*.json)
  shopt -u nullglob

  if (( ${#files[@]} == 0 )); then
    printf 'No profiles found in %s\n' "$PROFILES_DIR"
    return 0
  fi

  for file in "${files[@]}"; do
    basename "$file" .json
  done
}

detect_current_profile() {
  local current_normalized="$1"
  local -a files=()
  local file
  local profile_normalized

  shopt -s nullglob
  files=("$PROFILES_DIR"/*.json)
  shopt -u nullglob

  for file in "${files[@]}"; do
    validate_json "$file" >/dev/null 2>&1 || continue

    profile_normalized="$(normalize_json "$file")"
    if [[ "$current_normalized" == "$profile_normalized" ]]; then
      basename "$file" .json
      return 0
    fi
  done

  return 1
}

show_current() {
  ensure_dirs

  if [[ ! -f "$SETTINGS_FILE" ]]; then
    printf 'No settings.json yet at %s\n' "$SETTINGS_FILE"
    return 0
  fi

  validate_json "$SETTINGS_FILE"

  local current_name=""
  local current_normalized
  current_normalized="$(normalize_json "$SETTINGS_FILE")"

  if current_name="$(detect_current_profile "$current_normalized")"; then
    printf 'Current profile: %s\n' "$current_name"
  else
    printf 'Current profile: unknown\n'
  fi

  printf 'Settings file: %s\n' "$SETTINGS_FILE"
  printf '\n'

  if has_command jq; then
    jq . "$SETTINGS_FILE"
  else
    python3 -m json.tool "$SETTINGS_FILE"
  fi
}

warn_placeholder_token() {
  local file="$1"
  local validator=""
  local token=""

  validator="$(json_validator)"

  if [[ "$validator" == "jq" ]]; then
    token="$(jq -r '.env.ANTHROPIC_AUTH_TOKEN // empty' "$file" 2>/dev/null)"
  else
    token="$(python3 - "$file" 2>/dev/null <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    data = json.load(fh)

print(data.get("env", {}).get("ANTHROPIC_AUTH_TOKEN", ""))
PY
)"
  fi

  if [[ "$token" == "sk-填这里" ]]; then
    printf 'Warning: %s still contains a placeholder token.\n' "$file" >&2
  fi
}

use_profile() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: cc-switch use <profile>"
  validate_profile_name "$name"

  ensure_dirs
  local source_file
  source_file="$(profile_path "$name")"

  [[ -f "$source_file" ]] || die "Profile not found: $source_file"
  validate_json "$source_file"
  warn_placeholder_token "$source_file"

  if [[ -f "$SETTINGS_FILE" ]]; then
    backup_current
  else
    printf 'Initializing new settings file.\n'
  fi

  cp "$source_file" "$SETTINGS_FILE"
  printf 'Switched to profile: %s\n' "$name"
  printf 'Updated: %s\n' "$SETTINGS_FILE"
}

edit_profile() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: cc-switch edit <profile>"
  validate_profile_name "$name"

  ensure_dirs
  local file
  file="$(profile_path "$name")"
  [[ -f "$file" ]] || die "Profile not found: $file"

  local editor="${EDITOR:-nano}"
  "$editor" "$file"
}

new_profile() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: cc-switch new <profile>"
  validate_profile_name "$name"

  ensure_dirs

  if [[ ! -f "$SETTINGS_FILE" ]]; then
    die "Current settings not found: $SETTINGS_FILE"
  fi

  validate_json "$SETTINGS_FILE"

  local file
  file="$(profile_path "$name")"

  if [[ -e "$file" ]]; then
    die "Profile already exists: $file"
  fi

  cp "$SETTINGS_FILE" "$file"
  printf 'Created profile: %s\n' "$file"
}

restore_backup() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Usage: cc-switch restore <backup-file>"

  ensure_dirs

  local source_file
  source_file="$(backup_path "$name")"
  [[ -f "$source_file" ]] || die "Backup not found: $source_file"
  validate_json "$source_file"

  if [[ -f "$SETTINGS_FILE" ]]; then
    backup_current
  else
    printf 'Initializing new settings file.\n'
  fi

  cp "$source_file" "$SETTINGS_FILE"
  printf 'Restored backup: %s\n' "$source_file"
  printf 'Updated: %s\n' "$SETTINGS_FILE"
}

usage() {
  cat <<'EOF'
Usage:
  cc-switch list
  cc-switch use <profile>
  cc-switch current
  cc-switch backup
  cc-switch edit <profile>
  cc-switch new <profile>
  cc-switch restore <backup-file>

Examples:
  cc-switch list
  cc-switch use deepseek
  cc-switch current
  cc-switch restore settings-20260518-142604.json
EOF
}

main() {
  local command="${1:-help}"

  case "$command" in
    list)
      list_profiles
      ;;
    use)
      use_profile "${2:-}"
      ;;
    current)
      show_current
      ;;
    backup)
      backup_current
      ;;
    edit)
      edit_profile "${2:-}"
      ;;
    new)
      new_profile "${2:-}"
      ;;
    restore)
      restore_backup "${2:-}"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      die "Unknown command: $command"
      ;;
  esac
}

main "$@"
